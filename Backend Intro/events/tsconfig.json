{
  "compilerOptions": {
    "rootDir": "src/ts",
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom"],
    "types": [],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "src/ts", "src/ts"],
  "exclude": ["node_modules"]
}
